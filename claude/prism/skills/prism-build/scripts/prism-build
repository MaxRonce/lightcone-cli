#!/bin/bash
# Run a prism-build loop using CLAUDE.md as the spec
# Autonomous iteration from asp.yaml to materialized results
# Usage: prism-build [--max-iterations N] [--backend claude|codex] [-- extra-flags...]

set -e

MAX_ITERATIONS="${PRISM_BUILD_MAX_ITERATIONS:-25}"
BACKEND="${RALPH_BACKEND:-claude}"
EXTRA_FLAGS_FILE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --max-iterations)
            MAX_ITERATIONS="$2"
            shift 2
            ;;
        --backend)
            BACKEND="$2"
            shift 2
            ;;
        --)
            shift
            EXTRA_FLAGS_FILE=$(mktemp /tmp/prism-build-flags-XXXXXX.txt)
            printf '%s\n' "$@" > "$EXTRA_FLAGS_FILE"
            break
            ;;
        -*)
            echo "Unknown flag: $1"
            echo "Usage: prism-build [--max-iterations N] [--backend claude|codex] [-- extra-flags...]"
            exit 1
            ;;
        *)
            echo "Unknown argument: $1"
            exit 1
            ;;
    esac
done

SPEC_FILE="$(pwd)/CLAUDE.md"

if [[ ! -f "$SPEC_FILE" ]]; then
    echo "No CLAUDE.md found in $(pwd)"
    echo "Run 'prism init' or '/prism-new' first."
    exit 1
fi

# Check that CLAUDE.md has a build status field
if ! head -50 "$SPEC_FILE" | sed -n '/^---$/,/^---$/p' | grep -qiE '^build:'; then
    echo "No 'build:' field in CLAUDE.md frontmatter."
    echo "Add 'build: open' to the YAML frontmatter to start a build loop."
    exit 1
fi

# Sanitize session name (tmux doesn't allow dots or colons)
SESSION="prism-build-$(basename "$(pwd)" | tr -cd 'a-zA-Z0-9_-')"
WORK_DIR="$(pwd)"

if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Build loop already running: $SESSION"
    echo "  Attach: tmux attach -t $SESSION"
    exit 0
fi

LOOP_SCRIPT=$(mktemp /tmp/prism-build-loop-XXXXXX.sh)
trap "rm -f '$LOOP_SCRIPT'" EXIT

cat > "$LOOP_SCRIPT" << 'LOOP'
#!/bin/bash
SPEC_FILE="$1"
WORK_DIR="$2"
BACKEND="$3"
EXTRA_FLAGS_FILE="$4"
MAX_ITERATIONS="$5"

iteration=0

# Loop continues only while build status is explicitly "open" or "active"
check_status() {
    head -50 "$SPEC_FILE" | sed -n '/^---$/,/^---$/p' | grep -qiE '^build:[[:space:]]*(open|active)[[:space:]]*$'
}

# Read extra flags from file into an array
EXTRA_FLAGS_ARR=()
if [[ -n "$EXTRA_FLAGS_FILE" && -f "$EXTRA_FLAGS_FILE" ]]; then
    while IFS= read -r flag; do
        [[ -n "$flag" ]] && EXTRA_FLAGS_ARR+=("$flag")
    done < "$EXTRA_FLAGS_FILE"
fi

while check_status; do
    cd "$WORK_DIR"
    iteration=$((iteration + 1))

    if [[ $iteration -gt $MAX_ITERATIONS ]]; then
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "Max iterations reached ($MAX_ITERATIONS)"
        echo "Check progress: prism status"
        echo "Resume: set 'build: open' in CLAUDE.md and re-run"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        break
    fi

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "prism-build iteration $iteration / $MAX_ITERATIONS -- $(date '+%H:%M:%S')"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    # Build system prompt from CLAUDE.md
    SYSPROMPT_FILE=$(mktemp /tmp/prism-build-sys-XXXXXX.txt)
    {
        echo "prism-build iteration $iteration / $MAX_ITERATIONS."
        echo ""
        cat "$SPEC_FILE"
    } > "$SYSPROMPT_FILE"

    PROMPT="You are inside a prism-build loop -- autonomous iteration from specification to materialized results. Activate the prism-build skill and follow its instructions. Survey the current state, contribute the highest-value work, commit, and exit."

    if [[ "$BACKEND" == "codex" ]]; then
        codex --dangerously-bypass-approvals-and-sandbox \
            --config "developer_instructions=$(cat "$SYSPROMPT_FILE")" \
            "${EXTRA_FLAGS_ARR[@]}" \
            "$PROMPT"
    else
        claude -p --dangerously-skip-permissions \
            "${EXTRA_FLAGS_ARR[@]}" \
            --append-system-prompt "$(cat "$SYSPROMPT_FILE")" \
            "$PROMPT"
    fi

    rm -f "$SYSPROMPT_FILE"

    echo "--- Iteration $iteration complete ---"
    sleep 2
done

# Clean up extra flags file
[[ -n "$EXTRA_FLAGS_FILE" && -f "$EXTRA_FLAGS_FILE" ]] && rm -f "$EXTRA_FLAGS_FILE"

if check_status; then
    : # Max iterations hit, message already printed
else
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "prism-build complete -- $iteration iterations"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
fi

echo ""
echo "Session kept open for inspection. Type exit to close."
exec bash -l
LOOP

chmod +x "$LOOP_SCRIPT"

echo "Starting prism-build"
echo "  Spec:           $SPEC_FILE"
echo "  Backend:        $BACKEND"
echo "  Work dir:       $WORK_DIR"
echo "  Max iterations: $MAX_ITERATIONS"
if [[ -n "$EXTRA_FLAGS_FILE" && -f "$EXTRA_FLAGS_FILE" ]]; then
    echo "  Flags:          $(tr '\n' ' ' < "$EXTRA_FLAGS_FILE")"
fi

tmux new-session -d -s "$SESSION" -c "$WORK_DIR" \
    "bash -l '$LOOP_SCRIPT' '$SPEC_FILE' '$WORK_DIR' '$BACKEND' '${EXTRA_FLAGS_FILE:-}' '$MAX_ITERATIONS'"

echo "  Session:        $SESSION"
echo "  Attach:         tmux attach -t $SESSION"
